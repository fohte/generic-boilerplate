{%- set testable_subpackages = [] -%}
{%- for pkg in subpackages -%}
{%- if pkg.type == 'rust' or (pkg.type == 'node' and pkg.tests | default(true)) -%}
{%- set _ = testable_subpackages.append(pkg) -%}
{%- endif -%}
{%- endfor -%}
{#- Node subpackages that participate in pnpm install on CI: same `tests: false`
