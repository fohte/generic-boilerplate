{%- endfor %}
{%- endif %}

      - run: cargo fetch
{%- elif subpackages %}
{%- if has_node %}
{%- if is_workspace %}
{#- Workspace mode: single root install (pnpm only) #}

      - run: corepack enable

      - name: Get pnpm store directory
