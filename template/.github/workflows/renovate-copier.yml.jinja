name: Renovate copier

on:
  pull_request:
    types: [opened, synchronize]

permissions:
  contents: write
  pull-requests: write

jobs:
  copier-update:
    runs-on: ubuntu-slim
    if: >-
      github.actor == 'renovate[bot]' &&
      {% raw %}startsWith(github.head_ref, 'renovate/https-github.com-fohte-generic-boilerplate-'){% endraw %}

    steps:
      - name: Generate GitHub App token
        id: app-token
        uses: actions/create-github-app-token@v2
        with:
          app-id: {% raw %}${{ secrets.APP_ID }}{% endraw %}
          private-key: {% raw %}${{ secrets.APP_PRIVATE_KEY }}{% endraw %}

      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: {% raw %}${{ github.head_ref }}{% endraw %}
          token: {% raw %}${{ steps.app-token.outputs.token }}{% endraw %}

      - name: Restore executable bit on scripts/bootstrap
        run: |
          if [ -f scripts/bootstrap ]; then
            git update-index --chmod=+x scripts/bootstrap
          fi

      # git update-index --chmod=+x stages the change.
      # commit-action uses `git ls-files --modified` which only detects unstaged changes.
      # We need to unstage the changes so commit-action can detect them.
      - name: Unstage changes for commit-action
        run: git restore --staged .

      - name: Commit and push changes
        uses: suzuki-shunsuke/commit-action@v0.1.0
        with:
          commit_message: 'fix: restore executable bit on scripts/bootstrap'
          workflow: deny
          github_token: {% raw %}${{ steps.app-token.outputs.token }}{% endraw %}

  auto-merge:
    needs: copier-update
    runs-on: ubuntu-slim
    if: >-
      github.actor == 'renovate[bot]' &&
      {% raw %}startsWith(github.head_ref, 'renovate/https-github.com-fohte-generic-boilerplate-'){% endraw %}

    steps:
      - name: Check changed files
        id: check
        env:
          GH_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
          PR_NUMBER: {% raw %}${{ github.event.pull_request.number }}{% endraw %}
        run: |
          changed_files=$(gh pr diff "$PR_NUMBER" --name-only --repo {% raw %}${{ github.repository }}{% endraw %})
          echo "Changed files:"
          echo "$changed_files"

          # Check if all changed files are .copier-answers.yml
          if [ -z "$changed_files" ]; then
            echo "copier_only=false" >> "$GITHUB_OUTPUT"
            echo "No changed files detected"
          else
            non_copier_files=$(echo "$changed_files" | grep -v '^\.copier-answers\.yml$' || true)
            if [ -z "$non_copier_files" ]; then
              echo "copier_only=true" >> "$GITHUB_OUTPUT"
            else
              echo "copier_only=false" >> "$GITHUB_OUTPUT"
              echo "Non-copier files found:"
              echo "$non_copier_files"
            fi
          fi

      - name: Enable auto-merge
        if: steps.check.outputs.copier_only == 'true'
        env:
          GH_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
          PR_NUMBER: {% raw %}${{ github.event.pull_request.number }}{% endraw %}
        run: |
          # Try --auto first (enables auto-merge when CI is pending/required)
          # If PR is already in clean status, --auto fails with 'Pull request is in clean status'
          # In that case, fall back to direct merge
          if OUTPUT=$(gh pr merge "$PR_NUMBER" --squash --auto -R {% raw %}${{ github.repository }}{% endraw %} 2>&1); then
            echo "$OUTPUT"
            echo "Auto-merge enabled successfully"
          elif echo "$OUTPUT" | grep -q "clean status"; then
            echo "$OUTPUT"
            echo "PR is in clean status, merging directly"
            gh pr merge "$PR_NUMBER" --squash -R {% raw %}${{ github.repository }}{% endraw %}
          else
            echo "$OUTPUT"
            echo "Auto-merge failed with unexpected error"
            exit 1
          fi
