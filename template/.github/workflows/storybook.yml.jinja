{#- Helper variables -#}
{%- set is_monorepo = subpackages | default([]) | length > 0 -%}
{#- Slugify: lowercase, replace _ and / with -, remove @ -#}
{%- macro slug(name) %}{{ name | replace('_', '-') | replace('@', '') | replace('/', '-') | lower }}{% endmacro -%}
name: Storybook

on:
  push:
    branches:
      - main
  pull_request:

concurrency:
  group: {% raw %}storybook-${{ github.ref }}{% endraw %}
  cancel-in-progress: true

permissions:
  contents: read
  deployments: write
  pull-requests: write

jobs:
{%- if is_monorepo %}
{%- for pkg in storybook_pkgs %}
  detect-changes-{{ slug(pkg.name) }}:
    runs-on: ubuntu-slim
    outputs:
      changed: {% raw %}${{ steps.changes.outputs.any_changed }}{% endraw %}
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0
        with:
          fetch-depth: 2

      - name: Check for changes
        uses: tj-actions/changed-files@9426d40962ed5378910ee2e21d5f8c6fcbf2dd96 # v47.0.6
        id: changes
        with:
          files: |
            {{ pkg.name }}/**
            .github/workflows/storybook.yml
{%- if is_workspace %}
            package.json
            pnpm-lock.yaml
            pnpm-workspace.yaml
{%- endif %}

  deploy-{{ slug(pkg.name) }}:
    needs: detect-changes-{{ slug(pkg.name) }}
    if: needs.detect-changes-{{ slug(pkg.name) }}.outputs.changed == 'true'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0

      - uses: jdx/mise-action@e6a8b3978addb5a52f2b4cd9d91eafa7f0ab959d # v4.2.0
        with:
          version: 2026.7.0

      - run: corepack enable
{%- if is_workspace %}

      - name: Get pnpm store directory
        id: pnpm-store
        run: echo "path=$(pnpm store path)" >> "$GITHUB_OUTPUT"

      - name: Cache pnpm store
        uses: actions/cache@55cc8345863c7cc4c66a329aec7e433d2d1c52a9 # v6.1.0
        with:
          path: |
            {% raw %}${{ steps.pnpm-store.outputs.path }}{% endraw %}
          key: {% raw %}${{ runner.os }}-pnpm-store-${{ hashFiles('pnpm-lock.yaml') }}{% endraw %}
          restore-keys: {% raw %}${{ runner.os }}-pnpm-store-{% endraw %}

      - run: pnpm install --filter "{{ pkg.name }}..." --frozen-lockfile
{%- else %}

      - name: Get pnpm store directory
        id: pnpm-store
        run: echo "path=$(pnpm store path)" >> "$GITHUB_OUTPUT"

      - name: Cache pnpm store
        uses: actions/cache@55cc8345863c7cc4c66a329aec7e433d2d1c52a9 # v6.1.0
        with:
          path: |
            {% raw %}${{ steps.pnpm-store.outputs.path }}{% endraw %}
          key: {% raw %}${{ runner.os }}-pnpm-store-${{ hashFiles({% endraw %}'{{ pkg.name }}/pnpm-lock.yaml'{% raw %}) }}{% endraw %}
          restore-keys: {% raw %}${{ runner.os }}-pnpm-store-{% endraw %}

      - name: Install pnpm dependencies
        run: cd "{{ pkg.name }}" && pnpm install --frozen-lockfile
{%- endif %}

      - name: Build Storybook
        run: cd "{{ pkg.name }}" && pnpm run storybook:build

      - name: Create Cloudflare Pages project if not exists
        uses: cloudflare/wrangler-action@ebbaa1584979971c8614a24965b4405ff95890e0 # v4.0.0
        with:
          apiToken: {% raw %}${{ secrets.CLOUDFLARE_API_TOKEN }}{% endraw %}
          accountId: {% raw %}${{ secrets.CLOUDFLARE_ACCOUNT_ID }}{% endraw %}
          command: pages project create {{ slug(project_name) }}-{{ slug(pkg.name) }}-storybook --production-branch=main
        continue-on-error: true

      - name: Deploy to Cloudflare Pages
        id: deploy
        uses: cloudflare/wrangler-action@ebbaa1584979971c8614a24965b4405ff95890e0 # v4.0.0
        with:
          apiToken: {% raw %}${{ secrets.CLOUDFLARE_API_TOKEN }}{% endraw %}
          accountId: {% raw %}${{ secrets.CLOUDFLARE_ACCOUNT_ID }}{% endraw %}
          command: pages deploy {{ pkg.name }}/storybook-static --project-name={{ slug(project_name) }}-{{ slug(pkg.name) }}-storybook --branch={% raw %}${{ github.head_ref || 'main' }}{% endraw %} --commit-dirty=true

      - name: Comment preview URL on PR
        if: github.event_name == 'pull_request'
        uses: marocchino/sticky-pull-request-comment@5770ad5eb8f42dd2c4f34da00c94c5381e49af88 # v3.0.5
        with:
          header: storybook-preview-{{ slug(pkg.name) }}
          message: |
            ## Storybook Preview ({{ pkg.name }})

            {% raw %}${{ steps.deploy.outputs.pages-deployment-alias-url }}{% endraw %}
{%- endfor %}
{%- else %}
  detect-changes:
    runs-on: ubuntu-slim
    outputs:
      changed: {% raw %}${{ steps.changes.outputs.any_changed }}{% endraw %}
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0
        with:
          fetch-depth: 2

      - name: Check for changes
        uses: tj-actions/changed-files@9426d40962ed5378910ee2e21d5f8c6fcbf2dd96 # v47.0.6
        id: changes
        with:
          files: |
            src/**
            .storybook/**
            package.json
            pnpm-lock.yaml
            .github/workflows/storybook.yml

  deploy:
    needs: detect-changes
    if: needs.detect-changes.outputs.changed == 'true'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0

      - uses: jdx/mise-action@e6a8b3978addb5a52f2b4cd9d91eafa7f0ab959d # v4.2.0
        with:
          version: 2026.7.0

      - run: corepack enable

      - name: Get pnpm store directory
        id: pnpm-store
        run: echo "path=$(pnpm store path)" >> "$GITHUB_OUTPUT"

      - name: Cache pnpm store
        uses: actions/cache@55cc8345863c7cc4c66a329aec7e433d2d1c52a9 # v6.1.0
        with:
          path: |
            {% raw %}${{ steps.pnpm-store.outputs.path }}{% endraw %}
          key: {% raw %}${{ runner.os }}-pnpm-store-${{ hashFiles('pnpm-lock.yaml') }}{% endraw %}
          restore-keys: {% raw %}${{ runner.os }}-pnpm-store-{% endraw %}

      - run: pnpm install --frozen-lockfile

      - name: Build Storybook
        run: pnpm run storybook:build

      - name: Create Cloudflare Pages project if not exists
        uses: cloudflare/wrangler-action@ebbaa1584979971c8614a24965b4405ff95890e0 # v4.0.0
        with:
          apiToken: {% raw %}${{ secrets.CLOUDFLARE_API_TOKEN }}{% endraw %}
          accountId: {% raw %}${{ secrets.CLOUDFLARE_ACCOUNT_ID }}{% endraw %}
          command: pages project create {{ slug(project_name) }}-storybook --production-branch=main
        continue-on-error: true

      - name: Deploy to Cloudflare Pages
        id: deploy
        uses: cloudflare/wrangler-action@ebbaa1584979971c8614a24965b4405ff95890e0 # v4.0.0
        with:
          apiToken: {% raw %}${{ secrets.CLOUDFLARE_API_TOKEN }}{% endraw %}
          accountId: {% raw %}${{ secrets.CLOUDFLARE_ACCOUNT_ID }}{% endraw %}
          command: pages deploy storybook-static --project-name={{ slug(project_name) }}-storybook --branch={% raw %}${{ github.head_ref || 'main' }}{% endraw %} --commit-dirty=true

      - name: Comment preview URL on PR
        if: github.event_name == 'pull_request'
        uses: marocchino/sticky-pull-request-comment@5770ad5eb8f42dd2c4f34da00c94c5381e49af88 # v3.0.5
        with:
          header: storybook-preview
          message: |
            ## Storybook Preview

            {% raw %}${{ steps.deploy.outputs.pages-deployment-alias-url }}{% endraw %}
{%- endif %}
