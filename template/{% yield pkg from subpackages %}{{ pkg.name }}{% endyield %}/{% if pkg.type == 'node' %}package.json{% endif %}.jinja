{%- set has_storybook = pkg.storybook | default(false) -%}
{
  "name": "{{ pkg.name }}",
  "private": true,
{%- if not is_workspace %}
  "packageManager": "pnpm@11.3.0",
{%- endif %}
  "type": "module",
  "scripts": {
{%- if not is_workspace %}
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
{%- endif %}
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"{{ "," if has_storybook else "" }}
{%- if has_storybook %}
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
{%- endif %}
  }{{ "," if not is_workspace or has_storybook else "" }}
{%- if not is_workspace %}
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.2",
{%- if has_storybook %}
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-themes": "10.4.1",
    "@storybook/react-vite": "10.4.1",
{%- endif %}
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.4",
    "concurrently": "10.0.0",
    "eslint": "10.4.0",
{%- if has_storybook %}
    "eslint-plugin-storybook": "10.4.1",
{%- endif %}
    "prettier": "3.8.3",
{%- if has_storybook %}
    "storybook": "10.4.1",
{%- endif %}
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
{%- elif has_storybook %}
  "devDependencies": {
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-themes": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "storybook": "10.4.1"
  }
{%- endif %}
}
