{%- set is_workspace = monorepo_node_workspace | default(false) -%}
{
  "name": "{{ pkg.name }}",
  "private": true,
{%- if not is_workspace %}
  "packageManager": "pnpm@10.32.1",
{%- endif %}
  "type": "module",
  "scripts": {
{%- if not is_workspace %}
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
{%- endif %}
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"
  }{{ "," if not is_workspace else "" }}
{%- if not is_workspace %}
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.1",
    "@tsconfig/node-lts": "22.0.1",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "22.13.4",
    "concurrently": "9.2.1",
    "eslint": "10.0.3",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
{%- endif %}
}
