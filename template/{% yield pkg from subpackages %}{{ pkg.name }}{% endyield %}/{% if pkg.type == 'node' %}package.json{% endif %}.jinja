{%- set has_storybook = pkg.storybook | default(false) -%}
{
  "name": "{{ pkg.name }}",
  "private": true,
{%- if not is_workspace %}
  "packageManager": "pnpm@10.33.0",
{%- endif %}
  "type": "module",
  "scripts": {
{%- if not is_workspace %}
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
{%- endif %}
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"{{ "," if has_storybook else "" }}
{%- if has_storybook %}
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
{%- endif %}
  }{{ "," if not is_workspace or has_storybook else "" }}
{%- if not is_workspace %}
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.1",
{%- if has_storybook %}
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-themes": "10.3.3",
    "@storybook/react-vite": "10.3.3",
{%- endif %}
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.0",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
{%- if has_storybook %}
    "eslint-plugin-storybook": "10.3.3",
{%- endif %}
    "prettier": "3.8.1",
{%- if has_storybook %}
    "storybook": "10.3.3",
{%- endif %}
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
{%- elif has_storybook %}
  "devDependencies": {
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-themes": "10.3.3",
    "@storybook/react-vite": "10.3.3",
    "storybook": "10.3.3"
  }
{%- endif %}
}
