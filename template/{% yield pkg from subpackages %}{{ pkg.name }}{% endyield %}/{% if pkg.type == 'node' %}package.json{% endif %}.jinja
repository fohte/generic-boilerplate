{%- set has_storybook = pkg.storybook | default(false) -%}
{%- set has_tests = pkg.tests | default(true) -%}
{%- set has_scripts = has_tests or has_storybook -%}
{%- set has_dev_deps = (has_tests and not is_workspace) or has_storybook -%}
{
  "name": "{{ pkg.name }}",
  "private": true,
{%- if not is_workspace %}
  "packageManager": "pnpm@11.5.2",
{%- endif %}
  "type": "module"{{ "," if has_scripts else "" }}
{%- if has_scripts %}
  "scripts": {
{%- if has_tests and not is_workspace %}
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
{%- endif %}
{%- if has_tests %}
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"{{ "," if has_storybook else "" }}
{%- endif %}
{%- if has_storybook %}
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
{%- endif %}
  }{{ "," if has_dev_deps else "" }}
{%- endif %}
{%- if has_tests and not is_workspace %}
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.4",
{%- if has_storybook %}
    "@storybook/addon-docs": "10.4.3",
    "@storybook/addon-themes": "10.4.3",
    "@storybook/react-vite": "10.4.3",
{%- endif %}
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.1",
    "concurrently": "10.0.3",
    "eslint": "10.4.1",
{%- if has_storybook %}
    "eslint-plugin-storybook": "10.4.3",
{%- endif %}
    "prettier": "3.8.3",
{%- if has_storybook %}
    "storybook": "10.4.3",
{%- endif %}
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
{%- elif has_storybook %}
  "devDependencies": {
    "@storybook/addon-docs": "10.4.3",
    "@storybook/addon-themes": "10.4.3",
    "@storybook/react-vite": "10.4.3",
    "storybook": "10.4.3"
  }
{%- endif %}
}
