{%- set has_node = (type == 'node') or (subpackages | selectattr('type', 'equalto', 'node') | list | length > 0) -%}
{%- set has_rust = (type == 'rust') or (subpackages | selectattr('type', 'equalto', 'rust') | list | length > 0) -%}
[tools]
lefthook = "2.1.3"
{%- if has_rust %}
"github:ast-grep/ast-grep" = "0.41.0"
{%- endif %}

# lefthook hooks
actionlint = "1.7.11"
{%- if has_node and node_package_manager == 'pnpm' %}
node = "24.14.0"
{%- else %}
bun = "1.3.10"
{%- endif %}
"github:fohte/basefmt" = "0.1.0"
{% if type != 'node' and not (monorepo_node_workspace | default(false)) -%}
"npm:@commitlint/cli" = "20.4.3"
"npm:prettier" = "3.8.1"
{% endif -%}
shellcheck = "0.11.0"
shfmt = "3.12.0"

{%- if has_rust %}

[env]
# Share target dir across worktrees to avoid full recompilation
CARGO_TARGET_DIR = "{% raw %}{{config_root}}{% endraw %}/target"
{%- endif %}

{%- if not (has_node and node_package_manager == 'pnpm') %}

[settings]
npm.bun = true
{%- endif %}
