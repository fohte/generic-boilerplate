[tools]
lefthook = "2.1.9"
{%- if has_rust %}
"github:ast-grep/ast-grep" = "0.44.0"
{%- endif %}

# lefthook hooks
actionlint = "1.7.12"
"github:betterleaks/betterleaks" = "1.5.0"
node = "24.17.0"
pinact = "4.1.0"
"github:fohte/basefmt" = "0.1.0"
{% if not (type == 'node' or is_workspace) -%}
{#- Without a root package.json, prettier and commitlint must be hosted by mise. -#}
"npm:@commitlint/cli" = "21.1.0"
"npm:prettier" = "3.8.4"
{% endif -%}
shellcheck = "0.11.0"
shfmt = "3.13.1"

{%- if has_rust %}

[env]
# Share target dir across worktrees to avoid full recompilation
CARGO_TARGET_DIR = "{% raw %}{{config_root}}{% endraw %}/target"
{%- endif %}
