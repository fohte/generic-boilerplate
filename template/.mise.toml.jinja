{%- set has_node = (type == 'node') or (subpackages | selectattr('type', 'equalto', 'node') | list | length > 0) -%}
{%- set has_rust = (type == 'rust') or (subpackages | selectattr('type', 'equalto', 'rust') | list | length > 0) -%}
[tools]
lefthook = "2.1.4"
{%- if has_rust %}
"github:ast-grep/ast-grep" = "0.42.0"
{%- endif %}

# lefthook hooks
actionlint = "1.7.12"
node = "24.14.1"
pinact = "3.9.0"
"github:fohte/basefmt" = "0.1.0"
{% if not has_node -%}
{#- Without a package.json, prettier and commitlint must be hosted by mise. -#}
"npm:@commitlint/cli" = "20.5.0"
"npm:prettier" = "3.8.1"
{% endif -%}
shellcheck = "0.11.0"
shfmt = "3.13.0"

{%- if has_rust %}

[env]
# Share target dir across worktrees to avoid full recompilation
CARGO_TARGET_DIR = "{% raw %}{{config_root}}{% endraw %}/target"
{%- endif %}
