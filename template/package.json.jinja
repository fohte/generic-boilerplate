{%- set has_storybook = use_storybook | default(false) -%}
{%- set root_is_web_app = (type == 'node' and is_web_app | default(false)) -%}
{#- Root package.json is only emitted for `type == 'node'` or pnpm workspace
    setups. Non-workspace monorepos host prettier/commitlint via mise instead,
    so they never gain a root package.json (see copier.yml _exclude). -#}
{
  "name": "{{ project_name }}",
  "private": true,
{%- if is_workspace %}
  "workspaces": [
{%- for pkg in node_pkgs %}
    "{{ pkg.name }}"{{ "," if not loop.last else "" }}
{%- endfor %}
  ],
{%- endif %}
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
{%- if is_workspace %}
    "test": "pnpm -r run test"
{%- else %}
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"{{ "," if has_storybook else "" }}
{%- endif %}
{%- if has_storybook and not is_workspace %}
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
{%- endif %}
  },
{%- if root_is_web_app %}
  "dependencies": {
    "@fohte/service-kit": "0.1.3",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@sentry/node": "10.57.0",
    "@sentry/opentelemetry": "10.58.0"
  },
{%- endif %}
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.5",
{%- if has_storybook and not is_workspace %}
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-themes": "10.4.6",
    "@storybook/react-vite": "10.4.6",
{%- endif %}
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.2",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
{%- if has_storybook %}
    "eslint-plugin-storybook": "10.4.6",
{%- endif %}
    "prettier": "3.8.4",
{%- if has_storybook and not is_workspace %}
    "storybook": "10.4.6",
{%- endif %}
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
