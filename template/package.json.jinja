{%- set has_storybook = use_storybook | default(false) -%}
{#- Root package.json is only emitted for `type == 'node'` or pnpm workspace
    setups. Non-workspace monorepos host prettier/commitlint via mise instead,
    so they never gain a root package.json (see copier.yml _exclude). -#}
{
  "name": "{{ project_name }}",
  "private": true,
{%- if is_workspace %}
  "workspaces": [
{%- for pkg in node_pkgs %}
    "{{ pkg.name }}"{{ "," if not loop.last else "" }}
{%- endfor %}
  ],
{%- endif %}
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
{%- if is_workspace %}
    "test": "pnpm -r run test"
{%- else %}
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"{{ "," if has_storybook else "" }}
{%- endif %}
{%- if has_storybook and not is_workspace %}
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
{%- endif %}
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.4",
{%- if has_storybook and not is_workspace %}
    "@storybook/addon-docs": "10.4.4",
    "@storybook/addon-themes": "10.4.4",
    "@storybook/react-vite": "10.4.4",
{%- endif %}
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.2",
    "concurrently": "10.0.3",
    "eslint": "10.4.1",
{%- if has_storybook %}
    "eslint-plugin-storybook": "10.4.4",
{%- endif %}
    "prettier": "3.8.3",
{%- if has_storybook and not is_workspace %}
    "storybook": "10.4.4",
{%- endif %}
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
