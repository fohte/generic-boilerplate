{%- set has_storybook = use_storybook | default(false) -%}
{%- if type != 'node' and not is_workspace and has_node_pkg -%}
{#- Non-workspace monorepo with node subpackages:
    root package.json hosts tools that run at the repo root
    (prettier, commitlint) so lefthook can use `pnpm exec`. -#}
{
  "name": "{{ project_name }}",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "prettier": "3.8.3"
  }
}
{%- elif type != 'node' and not is_workspace -%}
{#- Non-workspace monorepo without node subpackages: only corepack pinning -#}
{
  "name": "{{ project_name }}",
  "private": true,
  "packageManager": "pnpm@10.33.4"
}
{%- else -%}
{
  "name": "{{ project_name }}",
  "private": true,
{%- if is_workspace %}
  "workspaces": [
{%- for pkg in node_pkgs %}
    "{{ pkg.name }}"{{ "," if not loop.last else "" }}
{%- endfor %}
  ],
{%- endif %}
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
{%- if is_workspace %}
    "test": "pnpm -r run test"
{%- else %}
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"{{ "," if has_storybook else "" }}
{%- endif %}
{%- if has_storybook and not is_workspace %}
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
{%- endif %}
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.1",
{%- if has_storybook and not is_workspace %}
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-themes": "10.4.0",
    "@storybook/react-vite": "10.4.0",
{%- endif %}
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.2",
    "concurrently": "9.2.1",
    "eslint": "10.4.0",
{%- if has_storybook %}
    "eslint-plugin-storybook": "10.4.0",
{%- endif %}
    "prettier": "3.8.3",
{%- if has_storybook and not is_workspace %}
    "storybook": "10.4.0",
{%- endif %}
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
{%- endif %}
