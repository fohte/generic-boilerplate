#!/usr/bin/env bash
# Auto-merge generic-boilerplate update PRs that only change the _commit
# version in .copier-answers.yml (no actual template diff).
#
# Usage: scripts/auto-merge-boilerplate-prs [--dry-run] [REPO...]
#
# Options:
#   --dry-run    Show what would be merged without actually merging
#
# Arguments:
#   REPO...      Specific repo names to process (default: all outdated repos with PRs)
#
# Requires: gh, jq

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

DRY_RUN=false
FILTER_REPOS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -*)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
    *)
      FILTER_REPOS+=("$1")
      shift
      ;;
  esac
done

# Collect outdated repos with Renovate PRs (tab-separated: repo\tnumber\turl)
jq_args=(--raw-output)
jq_filter='.[] | select(.renovate_pr != null)'
if [[ ${#FILTER_REPOS[@]} -gt 0 ]]; then
  repo_json=$(printf '%s\n' "${FILTER_REPOS[@]}" | jq -R . | jq -s .)
  jq_args+=(--argjson filter_repos "$repo_json")
  # shellcheck disable=SC2016
  jq_filter+=' | select(.repo as $r | $filter_repos | index($r))'
fi
jq_filter+=' | "\(.repo)\t\(.renovate_pr.number)\t\(.renovate_pr.url)"'

mapfile -t entries < <(
  "${SCRIPT_DIR}/list-boilerplate-usage" --outdated --json |
    jq "${jq_args[@]}" "$jq_filter"
)

if [[ ${#entries[@]} -eq 0 ]]; then
  echo "No outdated repos with Renovate PRs found."
  exit 0
fi

for entry in "${entries[@]}"; do
  IFS=$'\t' read -r repo number url <<< "$entry"

  # Get the diff and check if it only touches _commit in .copier-answers.yml
  diff=$(gh pr diff "$number" -R "fohte/$repo")

  # Count changed files: expect exactly one (a/... b/... pair)
  changed_files=$(printf '%s\n' "$diff" | grep -c '^diff --git')
  if [[ "$changed_files" -ne 1 ]]; then
    echo "SKIP $repo#$number ($url): $changed_files files changed"
    continue
  fi

  # Verify the only changed file is .copier-answers.yml
  changed_file=$(printf '%s\n' "$diff" | grep '^diff --git' | sed 's|diff --git a/\(.*\) b/.*|\1|')
  if [[ "$changed_file" != ".copier-answers.yml" ]]; then
    echo "SKIP $repo#$number ($url): changed file is $changed_file"
    continue
  fi

  # Verify only _commit line changed (added/removed lines excluding diff headers).
  # Use anchored patterns for diff headers to avoid matching content lines like
  # `----` (which a removed YAML `---` marker would produce).
  non_version_changes=$(printf '%s\n' "$diff" | grep '^[+-]' | grep -vE '^(--- |\+\+\+ )' | { grep -v '^[+-]_commit:' || true; } | wc -l)
  if [[ "$non_version_changes" -ne 0 ]]; then
    echo "SKIP $repo#$number ($url): non-version changes detected"
    continue
  fi

  if "$DRY_RUN"; then
    echo "WOULD MERGE $repo#$number ($url)"
  else
    echo "MERGING $repo#$number ($url)..."
    gh pr merge "$number" -R "fohte/$repo" --squash --auto
    echo "  -> auto-merge enabled"
  fi
done
